# =============================================================================
# ParkAddis — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
#
# The app validates all env vars at startup using Zod and will fail-fast
# if required values are missing or invalid.
# =============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
APP_NAME=ParkAddis
NODE_ENV=development              # development | production | test
PORT=3000
PUBLIC_URL=http://localhost:3000   # Must be HTTPS for Telegram Mini App & Webhooks

# ── Telegram Bot ────────────────────────────────────────────────────────────
# REQUIRED. Get your bot token from @BotFather on Telegram.
BOT_TOKEN=
BOT_USERNAME=                      # e.g. ParkAddisBot (for deep links)

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL + PostGIS connection string.
# Default: local dev (docker) on port 5433 to avoid conflicts with native PG.
DATABASE_URL=postgres://parking:parking@localhost:5433/parking
PGSSL=false                        # Enable SSL for cloud-hosted databases

# ── Search ──────────────────────────────────────────────────────────────────
DEFAULT_SEARCH_RADIUS_M=15000      # Default radius in metres
MAX_SEARCH_RESULTS=20              # Max spots returned per search

# ── Business ────────────────────────────────────────────────────────────────
DEFAULT_COMMISSION_PERCENT=15      # Platform commission (0-100)
CURRENCY=ETB

# ── Authentication ──────────────────────────────────────────────────────────
# REQUIRED. JWT secret for admin API authentication (min 8 chars).
JWT_SECRET=change-me-to-a-strong-secret
JWT_EXPIRY=24h                     # Token expiry (e.g. 24h, 7d)

# Admin bootstrap credentials (used only in dev mode for initial setup).
ADMIN_BOOTSTRAP_EMAIL=admin@parkaddis.com
ADMIN_BOOTSTRAP_PASSWORD=

# ── Chapa Payment Gateway ────────────────────────────────────────────────────
# Get your API keys from https://dashboard.chapa.co
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# ── Notifications ────────────────────────────────────────────────────────────
ENABLE_NOTIFICATIONS=true          # Enable/disable scheduled notifications
NOTIFICATION_CHECK_INTERVAL=5      # Minutes between notification checks

# ── Telegram Mode ───────────────────────────────────────────────────────────
# polling:   Simple long-polling (default, good for dev)
# webhook:   Webhook mode (production, requires HTTPS PUBLIC_URL)
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=              # Full webhook URL (required if mode=webhook)
TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# ── Security ────────────────────────────────────────────────────────────────
CORS_ORIGINS=*                     # Comma-separated origins or * for all
RATE_LIMIT_WINDOW_MS=900000        # Rate limit window (15 min = 900000ms)
RATE_LIMIT_MAX_REQUESTS=100        # Max requests per window per IP

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info                     # debug | info | warn | error
LOG_FORMAT=pretty                  # pretty (dev) | json (production)

# ── Map Tiles (optional) ────────────────────────────────────────────────────
# Override the tile server for static map images. Default is OSM public tiles.
# MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
