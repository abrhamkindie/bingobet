# ---- App ----
APP_NAME=BetBingo
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000

# ---- Telegram ----
# Get this from @BotFather
BOT_TOKEN=
# Username of the bot (no @)
BOT_USERNAME=

# ---- Database ----
# Matches docker-compose.yml defaults
DATABASE_URL=postgres://betbingo:betbingo@localhost:5434/betbingo
# Note: parking project uses port 5433, BetBingo uses 5434
PGSSL=false

# ---- Admin / JWT ----
JWT_SECRET=change-me-in-production-32-chars-min
JWT_EXPIRY=24h
ADMIN_BOOTSTRAP_EMAIL=admin@betbingo.com
ADMIN_BOOTSTRAP_PASSWORD=changeme123

# ---- Chapa Payment Gateway ----
# Get these from https://dashboard.chapa.co
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# ---- Business ----
CURRENCY=ETB

# ---- Telegram Mode ----
TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram
# TELEGRAM_WEBHOOK_PATH=/webhook/telegram

# ---- Security ----
CORS_ORIGINS=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Logging ----
LOG_LEVEL=info
LOG_FORMAT=pretty
