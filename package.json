{
  "name": "parking-bot",
  "version": "0.1.0",
  "description": "Telegram bot for finding and booking parking spots in Ethiopia (Addis Ababa)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "npm run admin:build && npm run miniapp:build && node src/index.js",
    "dev": "npm run admin:build && npm run miniapp:build && node --watch src/index.js",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:reset": "docker compose down -v && docker compose up -d db && node scripts/migrate.js && node scripts/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "admin:build": "vite build",
    "admin:dev": "vite build --watch",
    "miniapp:build": "vite build --config vite.miniapp.config.js",
    "miniapp:dev": "vite build --watch --config vite.miniapp.config.js",
    "lint": "eslint src scripts",
    "format": "prettier --write \"**/*.{js,json,md}\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "grammy": "^1.30.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.5.0",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "sharp": "^0.33.2",
    "staticmaps": "^1.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.9.0",
    "postcss": "^8.5.15",
    "prettier": "^3.3.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
